{
  "name": "evigate",
  "version": "0.2.0",
  "description": "A local CLI that verifies AI coding agents' \"done\" claims against execution evidence (tests, commands, diffs, instruction compliance).",
  "keywords": [
    "ai-agent",
    "llm",
    "coding-agent",
    "evidence",
    "verification",
    "audit",
    "cli",
    "claude-code",
    "codex"
  ],
  "license": "MIT",
  "author": "shiki-yusuke",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiki-yusuke/evigate.git"
  },
  "homepage": "https://github.com/shiki-yusuke/evigate#readme",
  "bugs": {
    "url": "https://github.com/shiki-yusuke/evigate/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "evigate": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
