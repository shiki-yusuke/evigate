{
  "name": "evigate",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence gate for AI coding agent completion claims — ingest and normalize past session transcripts.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "evigate": "./dist/cli.js"
  },
  "scripts": {
