{
  "_comment": "出典: prompts/05-dev-tool-ideas/12-corpus-and-fixtures.md のコマンド分類辞書。各パターンは「コマンドをシェル区切り(&&, ;, 改行, |, ||)で分割したセグメントの先頭」にのみアンカーする（^）。echo/rg/grep/cat/sed 等の引数内の文字列を誤って拾わないようにするため。composite は test+lint+build の複合として扱う。bun/bunx は実コーパスで多用されるため npm/pnpm/yarn/npx と並記した（2026-07-10 レビュー修正時、および Week 2 の実データ検証で bunx 抜けを追加発見・修正）。",
  "test": [
    "^(npx\\s+)?vitest\\b",
    "^(npx\\s+)?jest\\b",
    "^npm\\s+(run\\s+)?test\\b",
    "^pnpm\\s+test\\b",
    "^yarn\\s+test\\b",
    "^bun\\s+(run\\s+)?test\\b",
    "^bun\\s+(run\\s+)?vitest\\b",
    "^bunx\\s+vitest\\b",
    "^bunx\\s+jest\\b",
    "^pytest\\b"
  ],
  "lint": [
    "^(npx\\s+)?eslint\\b",
    "^biome\\s+check\\b",
    "^npm\\s+run\\s+lint\\b",
    "^pnpm\\s+lint\\b",
    "^bun\\s+run\\s+lint\\b",
    "^bunx\\s+eslint\\b"
  ],
  "build": [
    "^tsc\\b.*--noEmit",
    "^npm\\s+run\\s+build\\b",
    "^vite\\s+build\\b",
    "^bun\\s+run\\s+build\\b",
    "^bun\\s+run\\s+typecheck\\b",
    "^bunx\\s+tsc\\b.*--noEmit"
  ],
  "composite": {
    "patterns": ["^preflight\\b"],
    "expandsTo": ["test", "lint", "build"]
  }
}
